# ============================================================
# BLACKSITE NODE — .gitignore
# CRITICAL: Vault files must NEVER be committed to any VCS.
# A committed vault file exposes the encrypted blob to offline
# brute-force attacks with unlimited time and compute.
# ============================================================

# --- Vault files (the entire threat surface) ---
*.blacksite
*.blacksite.bak
vault.json
*.vault
test_vault*/

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Node / npm ---
node_modules/
dist/
dist-ssr/
*.local

# --- Rust / Cargo build artifacts ---
src-tauri/target/
src-tauri/Cargo.lock
Cargo.lock.bak

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Editor directories ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OS artifacts ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Export/Import files ---
*.bsx
*.csv

# --- Mobile / Android ---
src-tauri/gen/android/app/build/

# --- ML Engine: training artifacts (large, never commit) ---
ml_engine/data/
ml_engine/models/

# --- ML Engine: raw password datasets (sensitive + large) ---
*.txt
!README*.txt
ml_engine/**/*.txt

# --- ML Engine: TFLite files (not shipped; use ONNX) ---
ml_engine/exports/*.tflite

# --- ML Engine: Python cache ---
ml_engine/__pycache__/
ml_engine/**/__pycache__/

# --- ML Engine: keep these (ship with the app) ---
!ml_engine/exports/password_model.onnx
!ml_engine/exports/vocab.json
!ml_engine/exports/dataset_meta.json
